{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm run frontend:build",
    "frontendDist": "../src"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "productName": "QuiltSync",
  "mainBinaryName": "QuiltSync",
  "identifier": "com.quiltdata.quilt-sync",
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["quilt+s3"]
      }
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "QuiltSync",
        "width": 1280,
        "height": 900,
        "useHttpsScheme": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
