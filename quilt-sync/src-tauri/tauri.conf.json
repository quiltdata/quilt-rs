{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm run frontend:build",
    "frontendDist": "../src"
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["deb", "dmg", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "productName": "QuiltSync",
  "mainBinaryName": "QuiltSync",
  "identifier": "com.quiltdata.quilt-sync",
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["quilt+s3"]
      }
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/quiltdata/quilt-rs/releases/latest/download/latest.json",
        "https://www.quilt.bio/hubfs/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFGNTdCMUVDQUJBN0U1MkUKUldRdTVhZXI3TEZYcjdYSzdPM0VidFB1bzErUnVLdmk4amV4NXZhU0lOc290Q3dZTncrZTFFQTYK"
    }
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "capabilities": [
        {
          "identifier": "main-capability",
          "description": "Capability for the main window",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "shell:default",
            "deep-link:default",
            "process:default",
            "process:allow-restart",
            "updater:default",
            "updater:allow-check"
          ]
        }
      ]
    },
    "windows": [
      {
        "label": "main",
        "fullscreen": false,
        "resizable": true,
        "title": "QuiltSync",
        "width": 1280,
        "height": 900,
        "useHttpsScheme": true
      }
    ]
  }
}
