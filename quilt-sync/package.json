{
  "name": "quilt-sync",
  "description": "Cross-platform desktop application for editing Quilt data packages",
  "source": "src/assets/js/main.ts",
  "targets": {
    "default": {
      "distDir": "./src/dist"
    }
  },
  "scripts": {
    "build": "npm run frontend:build && npm run tauri:build",
    "build:deb": "npm run frontend:build && npm run tauri:build -- --bundles deb",
    "frontend:build": "parcel build",
    "frontend:check": "tsc --noEmit",
    "frontend:lint": "npm run frontend:lint:ts && npm run frontend:lint:css && npm run frontend:lint:md",
    "frontend:lint:css": "stylelint --fix **/*.css",
    "frontend:lint:md": "markdownlint --fix *.md",
    "frontend:lint:ts": "npx @biomejs/biome check --write ./src/assets/js/",
    "frontend:start": "parcel watch --no-hmr --target default",
    "prepare": "husky",
    "start": "concurrently \"npm run frontend:start\" \"npm run tauri:start\"",
    "tauri": "tauri",
    "tauri:build": "tauri build",
    "tauri:start": "tauri dev",
    "tauri:test": "cd src-tauri && cargo test",
    "test": "npm run frontend:check && npm run frontend:lint && npm run tauri:test"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.9",
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/plugin-deep-link": "^2.4.5",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.3",
    "@tauri-apps/plugin-updater": "^2.9.0",
    "vanilla-jsoneditor": "^3.11.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@tauri-apps/cli": "^2.9.6",
    "@typescript-eslint/types": "^8.53.0",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "markdownlint-cli": "^0.47.0",
    "parcel": "^2.16.3",
    "process": "^0.11.10",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1",
    "typescript": "^5.9.3"
  },
  "browserslist": "> 5%"
}
